{
  "name": "@everfir/videoinu-cli",
  "version": "0.1.0",
  "description": "Videoinu CLI — run AI workflows (image/video/audio generation) on videoinu.com. Designed for both humans and AI agents.",
  "license": "Apache-2.0",
  "author": "Everfir",
  "homepage": "https://github.com/everfir/videoinu-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/everfir/videoinu-cli.git"
  },
  "bugs": {
    "url": "https://github.com/everfir/videoinu-cli/issues"
  },
  "keywords": [
    "videoinu",
    "cli",
    "ai",
    "workflow",
    "video-generation",
    "image-generation",
    "audio-generation",
    "agent"
  ],
  "type": "module",
  "bin": {
    "videoinu": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "biome check",
    "format": "biome format --write",
    "knip": "knip",
    "check": "pnpm typecheck && pnpm lint && pnpm knip",
    "netdiag": "npx tsx scripts/netdiag.ts",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/node": "^22.0.0",
    "knip": "^6.7.0",
    "tsup": "^8.5.1",
    "typescript": "^5.3.3",
    "vitest": "^4.0.16"
  }
}
